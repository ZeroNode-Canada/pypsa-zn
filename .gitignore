# ------------------------------------------------------------------------------
# Python artifacts
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dll
*.egg-info/
.eggs/
build/
dist/

# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
venv/
.env/
.envrc
.pyenv/

# ------------------------------------------------------------------------------
# Jupyter / temp
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.log
*.tmp
*.bak

# ------------------------------------------------------------------------------
# OS / editor
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ------------------------------------------------------------------------------
# DevNet generated outputs (DO NOT COMMIT)
# ------------------------------------------------------------------------------
# Stress outputs
*/stress_out/
*/_preview/

# Logs
logs/
*/logs/

# Plots
plots/
*/plots/

# Exported PyPSA CSV networks (generated)
devnet-sld/
devnet-sld*/
devnetDC-sld/
devnetDC-sld*/

# ------------------------------------------------------------------------------
# DevNet config (user-editable — DO NOT COMMIT)
# ------------------------------------------------------------------------------
devnet_config/*.csv

# ------------------------------------------------------------------------------
# Large / generated data
# ------------------------------------------------------------------------------
*.xlsx
*.csv
*.json
*.png

# EXCEPT compliance artifacts
!compliance/

# EXCEPT reference artifacts
!devnet-stress-vectors/
!devnet-stress-vectors/**

# ------------------------------------------------------------------------------
# Reference outputs (keep controlled artifacts)
# ------------------------------------------------------------------------------
# Keep:
!devnet-stress-vectors/devnet_plots.xlsx
!devnet-stress-vectors/*.md
!devnet-stress-vectors/*.html

# Keep curated reference runs
!devnet-reference-runs/
!devnet-reference-runs/**
# Ignore logs
devnet-reference-runs/*/logs/

# ------------------------------------------------------------------------------
# Security / local paths
# ------------------------------------------------------------------------------
*.key
*.pem
*.env
*.secrets

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
*.zip
*.tar
*.gz
